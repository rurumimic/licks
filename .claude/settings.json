{
  "permissions": {
    "allow": [
      "Bash(cargo clippy --all-targets -- -D warnings)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/cargo-fmt.sh\"",
            "timeout": 30,
            "statusMessage": "Running cargo fmt..."
          }
        ]
      }
    ]
  }
}
